# =============================================================================
# Kirobi / Disruptive OS – .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# SICHERHEIT: Niemals committen!
# -----------------------------------------------------------------------------
.env
.env.local
.env.*.local
*.key
*.pem
*.p12
*.pfx
secrets/
infra/secrets/*.secret
infra/secrets/*.password
infra/secrets/*.token

# -----------------------------------------------------------------------------
# PRIVATE ZONEN: Persönliche und familiäre Inhalte
# -----------------------------------------------------------------------------
sacred/handoff-only.md
# Hinweis: sacred/ und experiences/family/ sind im Repo als Struktur vorhanden,
# echte persönliche Inhalte dürfen nie committed werden

# -----------------------------------------------------------------------------
# GROSSE MODELL-DATEIEN
# -----------------------------------------------------------------------------
models/local/*.bin
models/local/*.gguf
models/local/*.ggml
models/local/*.safetensors
models/local/*.pt
models/local/*.pth
models/embeddings/*.bin
*.gguf
*.ggml
*.safetensors
*.bin
*.pt
*.pth

# Ollama Modell-Daten (via Docker Volume)
.ollama/

# -----------------------------------------------------------------------------
# PYTHON
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
pip-wheel-metadata/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/
.python-version
*.pyc

# -----------------------------------------------------------------------------
# NODE.JS
# -----------------------------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
.pnpm-debug.log*
.npm
.eslintcache
.node_repl_history
*.tsbuildinfo
.next/
.nuxt/
.cache/
.parcel-cache/
dist/
.output/
.vercel/

# -----------------------------------------------------------------------------
# DOCKER & CONTAINER
# -----------------------------------------------------------------------------
docker-compose.override.yml
.dockerignore.local

# -----------------------------------------------------------------------------
# DATENBANKEN & PERSISTENTE DATEN
# -----------------------------------------------------------------------------
postgres_data/
qdrant_data/
ollama_data/
openwebui_data/
flowise_data/
*.sqlite
*.sqlite3
*.db

# -----------------------------------------------------------------------------
# LOGS
# -----------------------------------------------------------------------------
*.log
logs/
!kirobi-core/core-events.log

# -----------------------------------------------------------------------------
# IDE & EDITOR
# -----------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
.project
.classpath
.settings/

# -----------------------------------------------------------------------------
# TEMPORÄRE DATEIEN
# -----------------------------------------------------------------------------
*.tmp
*.temp
*.bak
*.orig
.cache/
tmp/

# -----------------------------------------------------------------------------
# QUARANTÄNE: Unverarbeitete Imports
# -----------------------------------------------------------------------------
quarantine/failed-ingests/*
quarantine/redacted/*
!quarantine/failed-ingests/README.md
!quarantine/redacted/README.md

# -----------------------------------------------------------------------------
# MEDIEN (Große Dateien)
# -----------------------------------------------------------------------------
sources/media/*.mp4
sources/media/*.mov
sources/media/*.avi
sources/video/*.mp4
sources/video/*.mov
sources/audio/*.wav
sources/audio/*.mp3
sources/images/*.psd
sources/images/*.raw
sources/models-3d/*.stl
sources/models-3d/*.obj

# -----------------------------------------------------------------------------
# BACKUP-ARCHIVES
# -----------------------------------------------------------------------------
*.tar.gz
*.zip
*.7z
archive/snapshots/*.tar.gz

# -----------------------------------------------------------------------------
# KIROBI LOCAL PYTHON CORE
# -----------------------------------------------------------------------------
.kirobi/
.pytest_cache/
extracts/family-private/profiles/*.sensitive.json
sacred/profiles/*.sensitive.json

# -----------------------------------------------------------------------------
# OBSIDIAN VAULT CONFIG
# -----------------------------------------------------------------------------
.obsidian/
