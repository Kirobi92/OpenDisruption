# =============================================================================
# Kirobi Reverse Proxy — Caddy
# =============================================================================
# Goals:
#   * Make the family PWA reachable at http(s)://kirobi.local AND at the
#     host's LAN IP from any device on the same network.
#   * Make the existing admin UIs reachable through ONE edge entry point
#     (LAN + Tailscale) without exposing their Docker ports directly.
#   * Terminate TLS locally with `tls internal` (Caddy's self-signed CA)
#     so service workers / "Install app" prompts work.
#   * Provide a stable /api/* surface for the PWA (no env-driven rewrites
#     in Next.js — Caddy is the single source of truth for routing).
#   * Keep all backends private (Docker network-only).
#
# The site addresses are templated from environment variables so the same
# Caddyfile works locally (`kirobi.local`), on a fixed LAN IP, or both at
# the same time. The defaults match the .env.example.
# =============================================================================

{
	# Global options — Caddy 2.x.
	admin off
	auto_https disable_redirects
	servers {
		trusted_proxies static private_ranges
	}
}

# --- HTTP (port 80) ----------------------------------------------------------
# We keep HTTP enabled so PWAs can be tried out without trusting a self-signed
# cert. Service workers ARE allowed on private RFC1918 IPs and on `*.local`.
:80 {
	encode zstd gzip
	@health path /healthz
	respond @health "ok" 200
	@not_edge_private {
		not remote_ip private_ranges 100.64.0.0/10
	}

	# Admin / workbench UIs. These are intentionally reachable only from
	# private LAN or Tailscale clients. Raw database/admin ports remain bound to
	# KIROBI_BIND_HOST (127.0.0.1 by default); Caddy is the only edge entry.
	redir /open-webui /open-webui/ 308
	handle /open-webui/* {
		respond @not_edge_private "Forbidden: private LAN or Tailscale only" 403
		uri strip_prefix /open-webui
		reverse_proxy open-webui:8080 {
			header_up X-Forwarded-Prefix /open-webui
			header_up Host {host}
		}
	}

	redir /flowise /flowise/ 308
	handle /flowise/* {
		respond @not_edge_private "Forbidden: private LAN or Tailscale only" 403
		uri strip_prefix /flowise
		reverse_proxy flowise:3000 {
			header_up X-Forwarded-Prefix /flowise
			header_up Host {host}
		}
	}

	redir /qdrant /qdrant/dashboard 308
	handle /qdrant/* {
		respond @not_edge_private "Forbidden: private LAN or Tailscale only" 403
		uri strip_prefix /qdrant
		reverse_proxy qdrant:6333 {
			header_up X-Forwarded-Prefix /qdrant
			header_up Host {host}
		}
	}

	redir /hermes /hermes/ 308
	handle /hermes/* {
		respond @not_edge_private "Forbidden: private LAN or Tailscale only" 403
		uri strip_prefix /hermes
		reverse_proxy hermes-runtime:9119 {
			header_up X-Forwarded-Prefix /hermes
			header_up Host {host}
		}
	}

	redir /openclaw /openclaw/ 308
	handle /openclaw/* {
		respond @not_edge_private "Forbidden: private LAN or Tailscale only" 403
		uri strip_prefix /openclaw
		reverse_proxy openclaw-gateway:18789 {
			header_up X-Forwarded-Prefix /openclaw
			header_up Host {host}
		}
	}

	# Dashboard: /dashboard* -> http://dashboard:3003
	redir /dashboard /dashboard/ 308
	handle /dashboard/* {
		reverse_proxy dashboard:3003 {
			header_up Host {host}
		}
	}

	# Auth service: /api/auth/* -> http://auth:8000/*
	handle_path /api/auth/* {
		reverse_proxy auth:8000 {
			header_up X-Forwarded-Prefix /api/auth
			header_up Host {host}
		}
	}

	# Analytics API: /api/analytics/* -> http://analytics:8010/*
	handle_path /api/analytics/* {
		reverse_proxy analytics:8010 {
			header_up X-Forwarded-Prefix /api/analytics
			header_up Host {host}
		}
	}

	# Image-Generation API: /api/image-generation/* -> http://image-generation:8011/*
	handle_path /api/image-generation/* {
		reverse_proxy image-generation:8011 {
			header_up X-Forwarded-Prefix /api/image-generation
			header_up Host {host}
		}
	}

	# Media-Processing API: /api/media-processing/* -> http://media-processing:8012/*
	handle_path /api/media-processing/* {
		reverse_proxy media-processing:8012 {
			header_up X-Forwarded-Prefix /api/media-processing
			header_up Host {host}
		}
	}

	# Music-Generation API: /api/music-generation/* -> http://music-generation:8013/*
	handle_path /api/music-generation/* {
		reverse_proxy music-generation:8013 {
			header_up X-Forwarded-Prefix /api/music-generation
			header_up Host {host}
		}
	}

	# Video-Generation API: /api/video-generation/* -> http://video-generation:8014/*
	handle_path /api/video-generation/* {
		reverse_proxy video-generation:8014 {
			header_up X-Forwarded-Prefix /api/video-generation
			header_up Host {host}
		}
	}

	# Voice service: /voice/* -> http://voice-processing:8001/*
	handle_path /voice/* {
		reverse_proxy voice-processing:8001 {
			header_up Host {host}
		}
	}

	# Generic API: /api/* -> http://api:8000/*
	handle_path /api/* {
		reverse_proxy api:8000 {
			header_up X-Forwarded-Prefix /api
			header_up Host {host}
		}
	}

	# Telegram Webhook: /telegram/* -> http://telegram:8005/*
	# PUBLIC — Telegram sendet von externen IPs; kein IP-Filter hier.
	handle_path /telegram/* {
		reverse_proxy telegram:8005 {
			header_up Host {host}
		}
	}

	# Embeddings Service: /embeddings/* -> http://embeddings:8000/*
	handle /embeddings/* {
		respond @not_edge_private "Forbidden: private LAN or Tailscale only" 403
		uri strip_prefix /embeddings
		reverse_proxy embeddings:8000 {
			header_up Host {host}
		}
	}

	# Ingest Service: /ingest/* -> http://ingest:8000/*
	handle /ingest/* {
		respond @not_edge_private "Forbidden: private LAN or Tailscale only" 403
		uri strip_prefix /ingest
		reverse_proxy ingest:8000 {
			header_up Host {host}
		}
	}

	# Retrieval Service: /retrieval/* -> http://retrieval:8000/*
	handle /retrieval/* {
		respond @not_edge_private "Forbidden: private LAN or Tailscale only" 403
		uri strip_prefix /retrieval
		reverse_proxy retrieval:8000 {
			header_up Host {host}
		}
	}

	# Model-Routing Service: /model-routing/* -> http://model-routing:8009/*
	handle /model-routing/* {
		respond @not_edge_private "Forbidden: private LAN or Tailscale only" 403
		uri strip_prefix /model-routing
		reverse_proxy model-routing:8009 {
			header_up Host {host}
		}
	}

	# Analytics Service: /analytics/* -> http://analytics:8010/*
	handle /analytics/* {
		respond @not_edge_private "Forbidden: private LAN or Tailscale only" 403
		uri strip_prefix /analytics
		reverse_proxy analytics:8010 {
			header_up Host {host}
		}
	}

	# Image-Generation Service: /image-generation/* -> http://image-generation:8011/*
	handle /image-generation/* {
		respond @not_edge_private "Forbidden: private LAN or Tailscale only" 403
		uri strip_prefix /image-generation
		reverse_proxy image-generation:8011 {
			header_up Host {host}
		}
	}

	# Media-Processing Service: /media-processing/* -> http://media-processing:8012/*
	handle /media-processing/* {
		respond @not_edge_private "Forbidden: private LAN or Tailscale only" 403
		uri strip_prefix /media-processing
		reverse_proxy media-processing:8012 {
			header_up Host {host}
		}
	}

	# Music-Generation Service: /music-generation/* -> http://music-generation:8013/*
	handle /music-generation/* {
		respond @not_edge_private "Forbidden: private LAN or Tailscale only" 403
		uri strip_prefix /music-generation
		reverse_proxy music-generation:8013 {
			header_up Host {host}
		}
	}

	# Video-Generation Service: /video-generation/* -> http://video-generation:8014/*
	handle /video-generation/* {
		respond @not_edge_private "Forbidden: private LAN or Tailscale only" 403
		uri strip_prefix /video-generation
		reverse_proxy video-generation:8014 {
			header_up Host {host}
		}
	}

	# Everything else -> Next.js PWA on port 3000.
	handle {
		reverse_proxy web:3000 {
			header_up Host {host}
		}
	}

	log {
		output stdout
		format console
		level INFO
	}
}

# --- HTTPS (port 443) with internal CA --------------------------------------
# Active only when KIROBI_HOSTNAME is set (e.g. kirobi.local). The matching
# certificate is signed by Caddy's internal root and lives in the caddy_data
# volume; trust it once on each device for the install prompt.
{$KIROBI_HOSTNAME:kirobi.local} {
	tls internal

	encode zstd gzip
	@health path /healthz
	respond @health "ok" 200
	@not_edge_private {
		not remote_ip private_ranges 100.64.0.0/10
	}

	redir /open-webui /open-webui/ 308
	handle /open-webui/* {
		respond @not_edge_private "Forbidden: private LAN or Tailscale only" 403
		uri strip_prefix /open-webui
		reverse_proxy open-webui:8080 {
			header_up X-Forwarded-Prefix /open-webui
			header_up Host {host}
		}
	}

	redir /flowise /flowise/ 308
	handle /flowise/* {
		respond @not_edge_private "Forbidden: private LAN or Tailscale only" 403
		uri strip_prefix /flowise
		reverse_proxy flowise:3000 {
			header_up X-Forwarded-Prefix /flowise
			header_up Host {host}
		}
	}

	redir /qdrant /qdrant/dashboard 308
	redir /qdrant/ /qdrant/dashboard/ 308
	handle /qdrant/* {
		respond @not_edge_private "Forbidden: private LAN or Tailscale only" 403
		uri strip_prefix /qdrant
		reverse_proxy qdrant:6333 {
			header_up X-Forwarded-Prefix /qdrant
			header_up Host {host}
		}
	}

	redir /hermes /hermes/ 308
	handle /hermes/* {
		respond @not_edge_private "Forbidden: private LAN or Tailscale only" 403
		uri strip_prefix /hermes
		reverse_proxy hermes-runtime:9119 {
			header_up X-Forwarded-Prefix /hermes
			header_up Host {host}
		}
	}

	redir /openclaw /openclaw/ 308
	handle /openclaw/* {
		respond @not_edge_private "Forbidden: private LAN or Tailscale only" 403
		uri strip_prefix /openclaw
		reverse_proxy openclaw-gateway:18789 {
			header_up X-Forwarded-Prefix /openclaw
			header_up Host {host}
		}
	}

	# Dashboard: /dashboard* -> http://dashboard:3003
	redir /dashboard /dashboard/ 308
	handle /dashboard/* {
		reverse_proxy dashboard:3003 {
			header_up Host {host}
		}
	}

	handle_path /api/auth/* {
		reverse_proxy auth:8000
	}

	# Analytics API: /api/analytics/* -> http://analytics:8010/*
	handle_path /api/analytics/* {
		reverse_proxy analytics:8010
	}

	# Image-Generation API: /api/image-generation/* -> http://image-generation:8011/*
	handle_path /api/image-generation/* {
		reverse_proxy image-generation:8011
	}

	# Media-Processing API: /api/media-processing/* -> http://media-processing:8012/*
	handle_path /api/media-processing/* {
		reverse_proxy media-processing:8012
	}

	# Music-Generation API: /api/music-generation/* -> http://music-generation:8013/*
	handle_path /api/music-generation/* {
		reverse_proxy music-generation:8013
	}

	# Video-Generation API: /api/video-generation/* -> http://video-generation:8014/*
	handle_path /api/video-generation/* {
		reverse_proxy video-generation:8014
	}

	handle_path /voice/* {
		reverse_proxy voice-processing:8001
	}
	handle_path /api/* {
		reverse_proxy api:8000
	}

	# Telegram Webhook: /telegram/* -> http://telegram:8005/*
	# PUBLIC — Telegram sendet von externen IPs; kein IP-Filter hier.
	handle_path /telegram/* {
		reverse_proxy telegram:8005
	}

	# Embeddings Service: /embeddings/* -> http://embeddings:8000/*
	handle /embeddings/* {
		respond @not_edge_private "Forbidden: private LAN or Tailscale only" 403
		uri strip_prefix /embeddings
		reverse_proxy embeddings:8000
	}

	# Ingest Service: /ingest/* -> http://ingest:8000/*
	handle /ingest/* {
		respond @not_edge_private "Forbidden: private LAN or Tailscale only" 403
		uri strip_prefix /ingest
		reverse_proxy ingest:8000
	}

	# Retrieval Service: /retrieval/* -> http://retrieval:8000/*
	handle /retrieval/* {
		respond @not_edge_private "Forbidden: private LAN or Tailscale only" 403
		uri strip_prefix /retrieval
		reverse_proxy retrieval:8000
	}

	# Model-Routing Service: /model-routing/* -> http://model-routing:8009/*
	handle /model-routing/* {
		respond @not_edge_private "Forbidden: private LAN or Tailscale only" 403
		uri strip_prefix /model-routing
		reverse_proxy model-routing:8009
	}

	# Analytics Service: /analytics/* -> http://analytics:8010/*
	handle /analytics/* {
		respond @not_edge_private "Forbidden: private LAN or Tailscale only" 403
		uri strip_prefix /analytics
		reverse_proxy analytics:8010
	}

	# Image-Generation Service: /image-generation/* -> http://image-generation:8011/*
	handle /image-generation/* {
		respond @not_edge_private "Forbidden: private LAN or Tailscale only" 403
		uri strip_prefix /image-generation
		reverse_proxy image-generation:8011
	}

	# Media-Processing Service: /media-processing/* -> http://media-processing:8012/*
	handle /media-processing/* {
		respond @not_edge_private "Forbidden: private LAN or Tailscale only" 403
		uri strip_prefix /media-processing
		reverse_proxy media-processing:8012
	}

	# Music-Generation Service: /music-generation/* -> http://music-generation:8013/*
	handle /music-generation/* {
		respond @not_edge_private "Forbidden: private LAN or Tailscale only" 403
		uri strip_prefix /music-generation
		reverse_proxy music-generation:8013
	}

	# Video-Generation Service: /video-generation/* -> http://video-generation:8014/*
	handle /video-generation/* {
		respond @not_edge_private "Forbidden: private LAN or Tailscale only" 403
		uri strip_prefix /video-generation
		reverse_proxy video-generation:8014
	}

	handle {
		reverse_proxy web:3000
	}

	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
	}

	log {
		output stdout
		format console
		level INFO
	}
}

# --- Dedicated HTTPS service roots --------------------------------------------
# Prefix proxies are fine for simple services, but Open WebUI/Flowise/Qdrant
# ship absolute root assets and APIs. Dedicated HTTPS ports keep them stable.
{$KIROBI_HOSTNAME:kirobi.local}:8441 {
	tls internal
	reverse_proxy open-webui:8080
}

{$KIROBI_HOSTNAME:kirobi.local}:8442 {
	tls internal
	reverse_proxy flowise:3000
}

{$KIROBI_HOSTNAME:kirobi.local}:8443 {
	tls internal
	reverse_proxy qdrant:6333
}
