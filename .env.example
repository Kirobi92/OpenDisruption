# =============================================================================
# Kirobi / Disruptive OS – Umgebungsvariablen
# Kopiere diese Datei zu .env und passe die Werte an
# WICHTIG: Niemals .env committen! Nur .env.example ist im Git
# =============================================================================

# -----------------------------------------------------------------------------
# SYSTEM
# -----------------------------------------------------------------------------
KIROBI_ENV=development
# Mögliche Werte: development, staging, production
KIROBI_LOG_LEVEL=info
# Mögliche Werte: debug, info, warning, error
KIROBI_TIMEZONE=Europe/Berlin

# -----------------------------------------------------------------------------
# OLLAMA (Lokales LLM)
# -----------------------------------------------------------------------------
OLLAMA_PORT=11434
OLLAMA_BASE_URL=http://localhost:11434
# Standard-Modell für allgemeine Anfragen
OLLAMA_DEFAULT_MODEL=llama3.1:8b
# Modell für komplexe Reasoning-Aufgaben
OLLAMA_REASONING_MODEL=deepseek-r1:32b
# Modell für Code-Aufgaben
OLLAMA_CODE_MODEL=qwen2.5-coder:32b
# Embedding-Modell
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
# GPU-Optionen (leer lassen für CPU-only)
OLLAMA_GPU_MEMORY_FRACTION=0.9
OLLAMA_NUM_PARALLEL=2

# -----------------------------------------------------------------------------
# OPEN WEBUI
# -----------------------------------------------------------------------------
OPENWEBUI_PORT=3000
OPENWEBUI_SECRET_KEY=AENDERE_DIESEN_SCHLUESSEL_SOFORT

# -----------------------------------------------------------------------------
# QDRANT (Vektor-Datenbank)
# -----------------------------------------------------------------------------
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT_URL=http://localhost:6333
# API-Key für Qdrant (leer lassen für no-auth in lokaler Umgebung)
QDRANT_API_KEY=
# Embedding-Dimensionen (je nach Modell)
QDRANT_EMBEDDING_DIM=768
# nomic-embed-text: 768, BGE-M3: 1024, text-embedding-ada-002: 1536

# -----------------------------------------------------------------------------
# POSTGRESQL
# -----------------------------------------------------------------------------
POSTGRES_PORT=5432
POSTGRES_HOST=localhost
POSTGRES_DB=kirobi
POSTGRES_USER=kirobi
POSTGRES_PASSWORD=AENDERE_DIESES_PASSWORT_SOFORT
POSTGRES_MAX_CONNECTIONS=100
DATABASE_URL=postgresql://kirobi:AENDERE_DIESES_PASSWORT_SOFORT@localhost:5432/kirobi

# -----------------------------------------------------------------------------
# FLOWISE (Workflow-Orchestrierung)
# -----------------------------------------------------------------------------
FLOWISE_PORT=3001
FLOWISE_USERNAME=admin
FLOWISE_PASSWORD=AENDERE_DIESES_PASSWORT_SOFORT
FLOWISE_SECRET_KEY=AENDERE_DIESEN_SCHLUESSEL_SOFORT
FLOWISE_LOG_LEVEL=info

# -----------------------------------------------------------------------------
# VOICE PROCESSING (Whisper STT + Piper TTS)
# -----------------------------------------------------------------------------
VOICE_PORT=8001
# Whisper Model: base, small, medium, large-v2, large-v3, turbo
WHISPER_MODEL=large-v3
# Device: cuda (GPU) or cpu
WHISPER_DEVICE=cuda
# Compute Type: float16, int8 (int8 uses less VRAM)
WHISPER_COMPUTE_TYPE=float16
# Language: de, en, etc.
VOICE_LANGUAGE=de
# Piper TTS Model Path (set automatically in container)
PIPER_MODEL_PATH=/models/piper/de_DE-thorsten-high.onnx
PIPER_CONFIG_PATH=/models/piper/de_DE-thorsten-high.onnx.json

# -----------------------------------------------------------------------------
# SUPERVISOR (Autonomous Agent Orchestration)
# -----------------------------------------------------------------------------
# Model for supervisor (recommended: llama3.1:70b or llama3.1:8b)
SUPERVISOR_MODEL=llama3.1:70b
# Main loop interval in seconds
SUPERVISOR_LOOP_INTERVAL=30
# Health check interval in seconds
HEALTH_CHECK_INTERVAL=60
# Task execution timeout in seconds
TASK_TIMEOUT=300

# -----------------------------------------------------------------------------
# LANGFUSE (LLM-Observability) – Optional
# -----------------------------------------------------------------------------
LANGFUSE_ENABLED=false
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
# Für selbst-gehostetes Langfuse:
# LANGFUSE_HOST=http://localhost:3002

# -----------------------------------------------------------------------------
# OPENOBSERVE (System-Monitoring) – Optional
# -----------------------------------------------------------------------------
OPENOBSERVE_ENABLED=false
OPENOBSERVE_PORT=5080
OPENOBSERVE_USERNAME=root@example.com
OPENOBSERVE_PASSWORD=AENDERE_DIESES_PASSWORT_SOFORT

# -----------------------------------------------------------------------------
# PERPLEXICA (Web-Recherche) – Optional
# -----------------------------------------------------------------------------
PERPLEXICA_ENABLED=false
PERPLEXICA_PORT=3010
PERPLEXICA_URL=http://localhost:3010

# -----------------------------------------------------------------------------
# CLOUD AI APIS – Optional (nur für nicht-sensible Aufgaben)
# -----------------------------------------------------------------------------
# OpenAI
OPENAI_API_KEY=
OPENAI_ORG_ID=
OPENAI_DEFAULT_MODEL=gpt-4o-mini

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_DEFAULT_MODEL=claude-3-haiku-20240307

# Google AI
GOOGLE_AI_API_KEY=
GOOGLE_AI_DEFAULT_MODEL=gemini-1.5-flash

# Groq (schnelle Inferenz)
GROQ_API_KEY=
GROQ_DEFAULT_MODEL=llama-3.1-8b-instant

# -----------------------------------------------------------------------------
# IMAGE GENERATION – Optional
# -----------------------------------------------------------------------------
STABLE_DIFFUSION_ENABLED=false
STABLE_DIFFUSION_URL=http://localhost:7860
REPLICATE_API_KEY=
FOFR_API_KEY=

# -----------------------------------------------------------------------------
# MICROSOFT 365 INTEGRATION – Optional
# -----------------------------------------------------------------------------
M365_ENABLED=false
M365_CLIENT_ID=
M365_CLIENT_SECRET=
M365_TENANT_ID=
M365_REDIRECT_URI=http://localhost:3000/auth/callback

# -----------------------------------------------------------------------------
# HOME ASSISTANT – Optional
# -----------------------------------------------------------------------------
HOME_ASSISTANT_ENABLED=false
HOME_ASSISTANT_URL=http://homeassistant.local:8123
HOME_ASSISTANT_TOKEN=

# -----------------------------------------------------------------------------
# VOICE PROCESSING – Optional
# -----------------------------------------------------------------------------
WHISPER_MODEL=base
# Mögliche Werte: tiny, base, small, medium, large
TTS_ENGINE=piper
# Mögliche Werte: piper, coqui, elevenlabs
ELEVENLABS_API_KEY=
VOICE_LANGUAGE=de-DE

# -----------------------------------------------------------------------------
# BACKUP-KONFIGURATION
# -----------------------------------------------------------------------------
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *
# Cron-Format: täglich um 02:00 Uhr
BACKUP_TARGET_DIR=/mnt/backup/kirobi
BACKUP_RETENTION_DAYS=30
BACKUP_ENCRYPT=true
BACKUP_ENCRYPTION_KEY=AENDERE_DIESEN_SCHLUESSEL_SOFORT

# -----------------------------------------------------------------------------
# KIROBI CORE EINSTELLUNGEN
# -----------------------------------------------------------------------------
# Maximale Kontext-Länge
KIROBI_MAX_CONTEXT_LENGTH=32768
# Timeout für Agenten-Antworten (Sekunden)
KIROBI_AGENT_TIMEOUT=120
# Human-in-the-Loop für kritische Aktionen
KIROBI_REQUIRE_HUMAN_CONFIRMATION=true
# Automatisches Event-Logging
KIROBI_EVENT_LOGGING=true
# Zone-Override für Entwicklung (NIEMALS in Production!)
KIROBI_DEV_ZONE_OVERRIDE=false
