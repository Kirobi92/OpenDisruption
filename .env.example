# =============================================================================
# Kirobi / Disruptive OS – Umgebungsvariablen
# Kopiere diese Datei zu .env und passe die Werte an
# WICHTIG: Niemals .env committen! Nur .env.example ist im Git
# =============================================================================

# -----------------------------------------------------------------------------
# SYSTEM
# -----------------------------------------------------------------------------
KIROBI_ENV=development
# Mögliche Werte: development, staging, production
KIROBI_LOG_LEVEL=info
# Mögliche Werte: debug, info, warning, error
KIROBI_TIMEZONE=Europe/Berlin
# Hostname/IP der lokalen Service-Stack (für kirobi_core status / doctor --live).
# Bleib auf 127.0.0.1, ausser du willst remote-Zugriff. Leer = compose-Default.
KIROBI_HOST=127.0.0.1
# Interface, an das Docker die Service-Ports bindet. 127.0.0.1 = local-first.
# Setze auf 0.0.0.0 nur, wenn das System bewusst im LAN sichtbar sein soll.
KIROBI_BIND_HOST=127.0.0.1
# Sicherster Komfort-Zugriff: Backends bleiben auf 127.0.0.1, nur Caddy ist
# im LAN/Tailscale sichtbar. Werte: local-only | lan | tailscale | lan-tailscale
KIROBI_ACCESS_MODE=lan-tailscale
# Optional: Tailscale MagicDNS-Name oder Tailscale-IP des Hosts für Doku/Status.
# Beispiel: opendisruption.tailnet-name.ts.net oder 100.100.100.100
KIROBI_TAILSCALE_HOST=
# Schaltet das Seeding der Supervisor-Queue aus dem kirobi_core-Backlog ein.
KIROBI_SEED_BACKLOG=false
KIROBI_SEED_LIMIT=5

# -----------------------------------------------------------------------------
# OLLAMA (Lokales LLM)
# -----------------------------------------------------------------------------
OLLAMA_PORT=11434
OLLAMA_BASE_URL=http://localhost:11434
# Standard-Modell für allgemeine Anfragen
OLLAMA_DEFAULT_MODEL=llama3.1:8b
# Modell für komplexe Reasoning-Aufgaben
OLLAMA_REASONING_MODEL=deepseek-r1:32b
# Modell für Code-Aufgaben
OLLAMA_CODE_MODEL=qwen2.5-coder:32b
# LLM-Provider für Telegram-Bots: auto | github | ollama
LLM_PROVIDER=auto
# GitHub Models / Copilot-nahe Cloud-Modelle für WORKSPACE-Dialoge
GITHUB_MODELS_URL=https://models.github.ai/inference/chat/completions
GITHUB_CHAT_MODEL=openai/gpt-4.1-mini
GITHUB_REASONING_MODEL=openai/gpt-4.1
GITHUB_CODE_MODEL=openai/gpt-4.1
# Embedding-Modell
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
# GPU-Optionen (leer lassen für CPU-only)
# RTX 3090 / 24 GB VRAM optimiert — anpassen für andere GPUs
OLLAMA_GPU_MEMORY_FRACTION=0.90
OLLAMA_NUM_PARALLEL=4
OLLAMA_MAX_LOADED_MODELS=2
OLLAMA_FLASH_ATTENTION=1
OLLAMA_KV_CACHE_TYPE=q8_0

# -----------------------------------------------------------------------------
# OPEN WEBUI
# -----------------------------------------------------------------------------
OPENWEBUI_PORT=3000
OPENWEBUI_SECRET_KEY=AENDERE_DIESEN_SCHLUESSEL_SOFORT

# -----------------------------------------------------------------------------
# QDRANT (Vektor-Datenbank)
# -----------------------------------------------------------------------------
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT_URL=http://localhost:6333
# API-Key für Qdrant (leer lassen für no-auth in lokaler Umgebung)
QDRANT_API_KEY=
# Embedding-Dimensionen (je nach Modell)
QDRANT_EMBEDDING_DIM=768
# nomic-embed-text: 768, BGE-M3: 1024, text-embedding-ada-002: 1536

# -----------------------------------------------------------------------------
# KIDI — Redis ContextDB (Profile: kidi)
# Starten mit: make kidi-up  |  docker compose --profile kidi up -d redis
# -----------------------------------------------------------------------------
# Redis-Passwort (leer = kein Auth — nur für lokale Entwicklung!)
# In Produktion: make bootstrap generiert ein zufälliges Passwort
KIROBI_REDIS_PASSWORD=
# Redis-Port (Default: 6379, gebunden an KIROBI_BIND_HOST)
KIROBI_REDIS_PORT=6379
# Redis-URL für Agenten (Default: redis://localhost:6379/0)
KIROBI_REDIS_URL=redis://localhost:6379/0
# Egress-Guard: "false" (Default) blockiert FAMILY_PRIVATE/SACRED-Schreibzugriffe
# Nur auf "true" setzen wenn externe Services explizit genehmigt sind
KIROBI_EGRESS_ALLOWED=false
# FAMILY PROFILES SYSTEM (NEU!)
# -----------------------------------------------------------------------------
# Authentication Service
AUTH_PORT=8002
JWT_SECRET_KEY=AENDERE_DIESEN_SCHLUESSEL_SOFORT_zu_einem_starken_Secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=30

# API Service
API_PORT=8003

# Web PWA
WEB_PORT=3002
# Optional Next.js dev rewrite — leave empty in production (Caddy handles it).
WEB_AUTH_UPSTREAM=
WEB_API_UPSTREAM=

# Voice App
VOICE_APP_PORT=3004

# -----------------------------------------------------------------------------
# REVERSE PROXY (Caddy) — entry point for the family PWA on the LAN
# -----------------------------------------------------------------------------
# Hostname under which the PWA is published via Avahi / mDNS.
KIROBI_HOSTNAME=kirobi.local
# Interface that Caddy listens on. 0.0.0.0 = exposed to LAN (intended).
# Für Tailscale/LAN-Zugriff bleibt KIROBI_BIND_HOST=127.0.0.1; nur dieser
# Caddy-Edge bindet öffentlich und routet zu den internen Diensten.
KIROBI_PROXY_BIND_HOST=0.0.0.0
CADDY_HTTP_PORT=80
CADDY_HTTPS_PORT=443
# Comma-separated browser origins that may call the auth/api services
# directly (CORS). Leave empty to allow localhost + *.local + RFC1918.
KIROBI_PUBLIC_ORIGINS=

# -----------------------------------------------------------------------------
# TELEGRAM (Phase 5, Option A: Restricted Bridge)
# -----------------------------------------------------------------------------
# Von Sven gewählt: Option A. Telegram bleibt standardmäßig AUS und darf nur
# PUBLIC/WORKSPACE über den zentralen Zone-Filter senden.
KIROBI_TELEGRAM_ENABLED=false
# Sicherste Token-Option: Docker Secrets / *_FILE. Keine Tokens in .env committen.
KIROBI_TELEGRAM_TOKEN_SOURCE=docker_secret
KIROBI_TELEGRAM_KEYBRODI_TOKEN_FILE=/run/secrets/telegram_keybrodi_token
KIROBI_TELEGRAM_OPENCODE_TOKEN_FILE=/run/secrets/telegram_opencode_token
KIROBI_TELEGRAM_OPENCLAW_TOKEN_FILE=/run/secrets/telegram_openclaw_token
KIROBI_TELEGRAM_HERMES_TOKEN_FILE=/run/secrets/telegram_hermes_token
KIROBI_TELEGRAM_OBSIDIAN_TOKEN_FILE=/run/secrets/telegram_obsidian_token
KIROBI_TELEGRAM_KIDI_TOKEN_FILE=/run/secrets/telegram_kidi_token
KIROBI_TELEGRAM_CHANNEL_ID_FILE=/run/secrets/telegram_channel_id
# Optional: separater Hermes-Bot parallel zum Hauptbot
HERMES_TELEGRAM_BOT_TOKEN=
HERMES_TELEGRAM_SERVICE_PORT=8015
HERMES_TELEGRAM_NOTIFY_ON_START=true
HERMES_TELEGRAM_WEBHOOK_HOST=

# -----------------------------------------------------------------------------
# DEFAULT USER (auth bootstrap on first start)
# -----------------------------------------------------------------------------
# The auth service creates this user once, if it doesn't exist yet, so the
# PWA's login screen is usable immediately. Set the password to an empty
# string to disable the bootstrap entirely.
KIROBI_DEFAULT_USER=sven
KIROBI_DEFAULT_PASSWORD=AENDERE_BEIM_ERSTEN_LOGIN
KIROBI_DEFAULT_DISPLAY_NAME=Sven
KIROBI_DEFAULT_ROLE=admin

# Default Passwords (nur für Ersteinrichtung - sofort ändern!)
DEFAULT_PASSWORD=kirobi2024

# -----------------------------------------------------------------------------
# POSTGRESQL
# -----------------------------------------------------------------------------
POSTGRES_PORT=5432
POSTGRES_HOST=localhost
POSTGRES_DB=kirobi
POSTGRES_USER=kirobi
POSTGRES_PASSWORD=AENDERE_DIESES_PASSWORT_SOFORT
POSTGRES_MAX_CONNECTIONS=100
DATABASE_URL=postgresql://kirobi:AENDERE_DIESES_PASSWORT_SOFORT@localhost:5432/kirobi

# -----------------------------------------------------------------------------
# FLOWISE (Workflow-Orchestrierung)
# -----------------------------------------------------------------------------
FLOWISE_PORT=3001
FLOWISE_USERNAME=admin
FLOWISE_PASSWORD=AENDERE_DIESES_PASSWORT_SOFORT
FLOWISE_SECRET_KEY=AENDERE_DIESEN_SCHLUESSEL_SOFORT
FLOWISE_LOG_LEVEL=info

# -----------------------------------------------------------------------------
# VOICE PROCESSING (Whisper STT + Piper TTS)
# -----------------------------------------------------------------------------
VOICE_PORT=8001
# Whisper Model: base, small, medium, large-v2, large-v3, turbo
WHISPER_MODEL=large-v3
# Device: cuda (GPU) or cpu
WHISPER_DEVICE=cuda
# Compute Type: float16, int8 (int8 uses less VRAM)
WHISPER_COMPUTE_TYPE=float16
# Language: de, en, etc.
VOICE_LANGUAGE=de
# Interner Basis-URL fuer Dienste wie Telegram -> local STT/TTS bridge
VOICE_SERVICE_URL=http://voice-processing:8001
# Piper TTS Model Path (set automatically in container)
PIPER_MODEL_PATH=/models/piper/de_DE-thorsten-high.onnx
PIPER_CONFIG_PATH=/models/piper/de_DE-thorsten-high.onnx.json

# -----------------------------------------------------------------------------
# SUPERVISOR (Autonomous Agent Orchestration)
# -----------------------------------------------------------------------------
# Model for supervisor (recommended: llama3.1:70b or llama3.1:8b)
SUPERVISOR_MODEL=llama3.1:70b
# Main loop interval in seconds
SUPERVISOR_LOOP_INTERVAL=30
# Health check interval in seconds
HEALTH_CHECK_INTERVAL=60
# Task execution timeout in seconds
TASK_TIMEOUT=300

# -----------------------------------------------------------------------------
# EMBEDDINGS SERVICE (Port 8004)
# -----------------------------------------------------------------------------
# Embedding-Modell (muss in Ollama verfügbar sein)
EMBEDDING_MODEL=nomic-embed-text
# Vektor-Dimension (nomic-embed-text: 768, BGE-M3: 1024, ada-002: 1536)
VECTOR_DIMENSION=768

# -----------------------------------------------------------------------------
# INGEST SERVICE (Port 8007)
# -----------------------------------------------------------------------------
# Kein zusätzlicher Config-Block nötig — nutzt POSTGRES_* und EMBEDDING_MODEL

# -----------------------------------------------------------------------------
# RETRIEVAL SERVICE (Port 8006)
# -----------------------------------------------------------------------------
# Modell für RAG-Antworten
OLLAMA_MODEL=llama3.1:8b
# Timeout für Ollama-Anfragen in Sekunden
OLLAMA_TIMEOUT=120

# -----------------------------------------------------------------------------
# LANGFUSE (LLM-Observability) – Optional
# -----------------------------------------------------------------------------
LANGFUSE_ENABLED=false
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
# Für selbst-gehostetes Langfuse:
# LANGFUSE_HOST=http://localhost:3002

# -----------------------------------------------------------------------------
# OPENOBSERVE (System-Monitoring) – Optional
# -----------------------------------------------------------------------------
OPENOBSERVE_ENABLED=false
OPENOBSERVE_PORT=5080
OPENOBSERVE_USERNAME=root@example.com
OPENOBSERVE_PASSWORD=AENDERE_DIESES_PASSWORT_SOFORT

# -----------------------------------------------------------------------------
# PERPLEXICA (Web-Recherche) – Optional
# -----------------------------------------------------------------------------
PERPLEXICA_ENABLED=false
PERPLEXICA_PORT=3010
PERPLEXICA_URL=http://localhost:3010

# -----------------------------------------------------------------------------
# CLOUD AI APIS – Optional (nur für nicht-sensible Aufgaben)
# -----------------------------------------------------------------------------
# OpenAI
OPENAI_API_KEY=
OPENAI_ORG_ID=
OPENAI_DEFAULT_MODEL=gpt-4o-mini

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_DEFAULT_MODEL=claude-3-haiku-20240307

# Google AI
GOOGLE_AI_API_KEY=
GOOGLE_AI_DEFAULT_MODEL=gemini-1.5-flash

# Groq (schnelle Inferenz)
GROQ_API_KEY=
GROQ_DEFAULT_MODEL=llama-3.1-8b-instant

# -----------------------------------------------------------------------------
# IMAGE GENERATION – Optional
# -----------------------------------------------------------------------------
STABLE_DIFFUSION_ENABLED=false
STABLE_DIFFUSION_URL=http://localhost:7860
REPLICATE_API_KEY=
FOFR_API_KEY=

# -----------------------------------------------------------------------------
# MICROSOFT 365 INTEGRATION – Optional
# -----------------------------------------------------------------------------
M365_ENABLED=false
M365_CLIENT_ID=
M365_CLIENT_SECRET=
M365_TENANT_ID=
M365_REDIRECT_URI=http://localhost:3000/auth/callback

# -----------------------------------------------------------------------------
# HOME ASSISTANT – Optional
# -----------------------------------------------------------------------------
HOME_ASSISTANT_ENABLED=false
HOME_ASSISTANT_URL=http://homeassistant.local:8123
HOME_ASSISTANT_TOKEN=

# -----------------------------------------------------------------------------
# VOICE PROCESSING – Optional
# -----------------------------------------------------------------------------
WHISPER_MODEL=base
# Mögliche Werte: tiny, base, small, medium, large
TTS_ENGINE=piper
# Mögliche Werte: piper, coqui, elevenlabs
ELEVENLABS_API_KEY=
VOICE_LANGUAGE=de-DE

# -----------------------------------------------------------------------------
# TELEGRAM BOT (KeyCodi / Kirobi-Interface)
# -----------------------------------------------------------------------------
# Bot-Token von @BotFather — NIEMALS committen!
TELEGRAM_BOT_TOKEN=
# Kommagetrennte Telegram-User-IDs, die den Bot nutzen dürfen (z.B. deine eigene ID)
TELEGRAM_ALLOWED_USER_IDS=
# Optional: Channel-ID für System-Benachrichtigungen (z.B. -1003782255463)
TELEGRAM_NOTIFY_CHANNEL_ID=
# Optional: Startup-Benachrichtigung senden (false vermeidet Fehler bei nicht verknuepften Channels)
TELEGRAM_NOTIFY_ON_START=false
# Webhook-URL (nur wenn Kirobi öffentlich erreichbar; leer = Long-Polling)
TELEGRAM_WEBHOOK_HOST=
# Port des Telegram-Bot-Services
TELEGRAM_SERVICE_PORT=8005
# Fortschritts-Update fuer lange Telegram-Agenten-Anfragen (Sekunden)
KIROBI_TELEGRAM_PROGRESS_INTERVAL_SEC=60
# Bot-Login: Passwort für den automatischen JWT-Login beim Start.
# Wenn leer, wird KIROBI_DEFAULT_PASSWORD als Fallback genutzt.
# Der Bot logt sich als KIROBI_BOT_USER (default: KIROBI_DEFAULT_USER) ein.
KIROBI_BOT_USER=
KIROBI_BOT_PASSWORD=

# -----------------------------------------------------------------------------
# BACKUP-KONFIGURATION
# -----------------------------------------------------------------------------
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *
# Cron-Format: täglich um 02:00 Uhr
BACKUP_TARGET_DIR=/mnt/backup/kirobi
BACKUP_RETENTION_DAYS=30
BACKUP_ENCRYPT=true
BACKUP_ENCRYPTION_KEY=AENDERE_DIESEN_SCHLUESSEL_SOFORT

# -----------------------------------------------------------------------------
# KIROBI CORE EINSTELLUNGEN
# -----------------------------------------------------------------------------
# Maximale Kontext-Länge
KIROBI_MAX_CONTEXT_LENGTH=32768
# Timeout für Agenten-Antworten (Sekunden)
KIROBI_AGENT_TIMEOUT=120
# Human-in-the-Loop für kritische Aktionen
KIROBI_REQUIRE_HUMAN_CONFIRMATION=true
# Automatisches Event-Logging
KIROBI_EVENT_LOGGING=true
# Zone-Override für Entwicklung (NIEMALS in Production!)
KIROBI_DEV_ZONE_OVERRIDE=false

# ── Neue Services (Phase 1 Upgrade) ─────────────────────────────────────────
EMBEDDINGS_SERVICE_PORT=8006
EMBED_MODEL=nomic-embed-text
INGEST_SERVICE_PORT=8007
RETRIEVAL_SERVICE_PORT=8008
MODEL_ROUTING_PORT=8009
MODEL_CHAT_PRIMARY=llama3.1:8b
MODEL_CODE_PRIMARY=qwen2.5-coder:7b
MODEL_REASONING_PRIMARY=deepseek-r1:7b
MODEL_CHAT_FALLBACK=llama3.2:3b
MODEL_CODE_FALLBACK=llama3.1:8b
MODEL_REASONING_FALLBACK=llama3.1:8b

# ── Image Generation Service (Port 8011) ─────────────────────────────────────
IMAGE_STORAGE_PATH=/data/images
