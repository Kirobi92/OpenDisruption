// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`StoryMusicHealthConfig — DOM-Snapshot-Regression > Snapshot: Default (source=default, refresh_s=30) 1`] = `
<div
  class="gpuPanel"
  data-testid="music-health-config-panel"
  style="margin-bottom: 14px;"
>
  <strong>
    ⏱️ Music-Health Refresh-Config
  </strong>
  <div
    style="font-size: 11px; color: rgb(170, 170, 170); margin-top: 6px;"
  >
    <span
      style="margin-right: 12px;"
    >
      Interval: 
      <strong
        data-testid="refresh-s"
        style="color: rgb(224, 224, 224);"
      >
        30
        s
      </strong>
    </span>
    <span
      style="margin-right: 12px;"
    >
      Quelle: 
      <strong
        data-testid="source-label"
        style="color: rgb(121, 134, 203);"
      >
        ⚙️ Default
      </strong>
    </span>
    <span>
      ENV: 
      <code
        style="font-size: 10px; color: rgb(136, 136, 136);"
      >
        KIROBI_MUSIC_HEALTH_REFRESH_S
      </code>
    </span>
  </div>
  <button
    data-testid="edit-button"
    style="margin-top: 8px; padding: 3px 10px; font-size: 11px; background: rgb(42, 42, 58); color: rgb(144, 202, 249); border: 1px solid rgb(68, 68, 68); border-radius: 4px; cursor: pointer;"
  >
    ✏️ Interval ändern
  </button>
</div>
`;

