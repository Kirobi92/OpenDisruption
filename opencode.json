{
  "$schema": "https://opencode.ai/config.json",

  "default_agent": "keycodi",

  "instructions": [
    "AGENTS.md",
    "CLAUDE.md"
  ],

  "permission": {
    "edit": "allow",
    "bash": "ask",
    "read": "allow",
    "glob": "allow",
    "grep": "allow",
    "task": "allow",
    "webfetch": "ask",
    "skill": "allow",
    "todowrite": "allow"
  },

  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": false
    },

    "gh-grep": {
      "type": "remote",
      "url": "https://mcp.grep.app",
      "enabled": false
    },

    "kirobi-context-db": {
      "type": "local",
      "command": ["python3", "-m", "kidi", "serve", "--port", "7700"],
      "enabled": true,
      "note": "KeyCodi Context-DB MCP-Server — SQLite-basiert, Zone-aware"
    },

    "kirobi-supervisor": {
      "type": "local",
      "command": ["python3", "-m", "kirobi_core", "status", "--json"],
      "enabled": true
    }
  },

  "agent": {
    "keycodi": {
      "model": "github-copilot/gpt-5.5",
      "reasoning": {
        "effort": "high",
        "summary": "auto"
      },
      "permission": {
        "task": {
          "*": "allow"
        },
        "bash": {
          "*": "ask",
          "python3 -m pytest*": "allow",
          "python3 -m kirobi_core*": "allow",
          "docker compose config*": "allow",
          "docker compose ps*": "allow",
          "docker compose build*": "allow",
          "docker compose --profile*": "allow",
          "git status*": "allow",
          "git log*": "allow",
          "git diff*": "allow",
          "git add*": "allow",
          "git commit*": "allow",
          "gh issue*": "allow",
          "gh pr*": "allow",
          "gh label*": "allow",
          "make test*": "allow",
          "make kidi*": "allow",
          "make agent*": "allow",
          "shellcheck*": "allow"
        }
      }
    },

    "build": {
      "permission": {
        "bash": {
          "*": "ask",
          "python3 -m pytest*": "allow",
          "python3 -m kirobi_core*": "allow",
          "docker compose config*": "allow"
        }
      }
    },

    "kirobi-architect": {
      "model": "github-copilot/gpt-5.5",
      "reasoning": { "effort": "high", "summary": "auto" }
    },
    "kirobi-coder": {
      "model": "github-copilot/gpt-5.5",
      "reasoning": { "effort": "medium", "summary": "auto" }
    },
    "kirobi-ops": {
      "model": "github-copilot/gpt-5.5",
      "reasoning": { "effort": "medium", "summary": "auto" }
    },
    "kirobi-frontend": {
      "model": "github-copilot/gpt-5.5",
      "reasoning": { "effort": "medium", "summary": "auto" }
    },
    "kirobi-reviewer": {
      "model": "github-copilot/gpt-5.5",
      "reasoning": { "effort": "high", "summary": "auto" }
    },
    "kirobi-docs": {
      "model": "github-copilot/gpt-5.5",
      "reasoning": { "effort": "low", "summary": "auto" }
    }
  },

  "watcher": {
    "ignore": [
      "node_modules/**",
      ".git/**",
      "__pycache__/**",
      "*.pyc",
      "archive/snapshots/**",
      "sacred/**",
      "data/**",
      ".kirobi/reports/**"
    ]
  },

  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 12000
  },

  "autoupdate": true,

  "share": "manual"
}
